---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  image?: string;
}

const { title, description, date, category, tags, image } = Astro.props;
const dateStr = date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} image={image}>
  <article class="post">
    {image && <img src={image} alt={title} class="post-hero" />}
    <div class="post-header">
      <span class="post-category">{category}</span>
      <h1>{title}</h1>
      <time>{dateStr}</time>
    </div>
    <div class="post-content">
      <slot />
    </div>
    <div class="post-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  .post-hero {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 2rem;
  }
  .post-header {
    margin-bottom: 2rem;
  }
  .post-category {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 700;
  }
  .post-header h1 {
    font-size: 2rem;
    margin: 0.5rem 0;
  }
  .post-header time {
    font-size: 0.85rem;
    color: #999;
  }
  .post-content {
    font-size: 1.05rem;
    line-height: 2;
  }
  .post-content h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.4rem;
  }
  .post-content p {
    margin-bottom: 1.25rem;
  }
  .post-content blockquote {
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
    color: #555;
    margin: 1.5rem 0;
  }
  .post-tags {
    margin-top: 3rem;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-muted);
    border-radius: 4px;
    color: var(--color-text);
  }
</style>
