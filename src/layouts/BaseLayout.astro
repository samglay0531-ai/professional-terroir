---
// src/layouts/BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = '用品飲的細膩，讀職場的風土', image } = Astro.props;
const siteTitle = '職場風土學';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script data-goatcounter="https://professionalterroir.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function() {
        var hash = window.location.hash;
        if (hash && (hash.includes("recovery_token") || hash.includes("invite_token") || hash.includes("confirmation_token"))) {
          window.location.href = "/admin/" + hash;
          return;
        }
        if (window.netlifyIdentity) {
          window.netlifyIdentity.on("init", function(user) {
            if (!user) {
              window.netlifyIdentity.on("login", function() {
                document.location.href = "/admin/";
              });
            }
          });
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
