---
interface Post {
  title: string;
  slug: string;
  tags: string[];
  date: Date;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

// Collect all unique tags
const allTags = [...new Set(posts.flatMap(p => p.tags))].sort();
---

<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <h3>標籤</h3>
    <div class="tag-list" id="tag-list">
      {allTags.map(tag => (
        <button class="tag-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>
  </div>
  <div class="sidebar-section">
    <h3>最新文章</h3>
    <ul class="recent-list" id="recent-list">
      {posts.map(post => {
        const dateStr = post.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
        return (
          <li data-tags={JSON.stringify(post.tags)}>
            <a href={`/blog/${post.slug}/`}>{post.title}</a>
            <time>{dateStr}</time>
          </li>
        );
      })}
    </ul>
  </div>
</aside>

<script is:inline>
(function() {
  var activeTag = null;
  var buttons = document.querySelectorAll('#tag-list .tag-btn');
  var items = document.querySelectorAll('#recent-list li');

  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tag = btn.getAttribute('data-tag');

      if (activeTag === tag) {
        activeTag = null;
        btn.classList.remove('active');
      } else {
        activeTag = tag;
        buttons.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
      }

      items.forEach(function(li) {
        var tags = JSON.parse(li.getAttribute('data-tags') || '[]');
        if (!activeTag || tags.indexOf(activeTag) !== -1) {
          li.style.display = '';
        } else {
          li.style.display = 'none';
        }
      });
    });
  });
})();
</script>

<style>
  .sidebar {
    position: sticky;
    top: 2rem;
  }
  .sidebar-section {
    margin-bottom: 2rem;
  }
  .sidebar-section h3 {
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--color-text);
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-btn {
    font-size: 0.8rem;
    padding: 0.25rem 0.75rem;
    background: var(--color-muted);
    border: none;
    border-radius: 4px;
    color: var(--color-text);
    cursor: pointer;
    font-family: var(--font-body);
    transition: background 0.2s, color 0.2s;
  }
  .tag-btn:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }
  .tag-btn.active {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .recent-list {
    list-style: none;
    padding: 0;
  }
  .recent-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-muted);
  }
  .recent-list li:last-child {
    border-bottom: none;
  }
  .recent-list a {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.5;
    display: block;
  }
  .recent-list a:hover {
    color: var(--color-primary);
  }
  .recent-list time {
    font-size: 0.75rem;
    color: #999;
  }
</style>
